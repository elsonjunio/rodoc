{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Extract: Run",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/main.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "extract",
                "--source", "/path/to/repo",
                "--output", "/path/to/extracted"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Extract: Run (verbose)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/main.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "--verbose",
                "extract",
                "--source", "/path/to/repo",
                "--output", "/path/to/extracted"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Normalize: Run",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/main.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "normalize",
                "--source", "/path/to/extracted",
                "--output", "/path/to/normalized"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Normalize: Run (verbose)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/main.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "--verbose",
                "normalize",
                "--source", "/path/to/extracted",
                "--output", "/path/to/normalized"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Index: Run",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/main.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "index",
                "--source", "/path/to/normalized",
                "--output", "/path/to/vectorstore",
                "--technology", "angular",
                "--version", "20"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Index: Run (verbose)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/main.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "--verbose",
                "index",
                "--source", "/path/to/normalized",
                "--output", "/path/to/vectorstore",
                "--technology", "angular",
                "--version", "20"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "MCP Server: Start",
            "type": "debugpy",
            "request": "launch",
            "module": "mcp_docs_server",
            "python": "${workspaceFolder}/.venv/bin/python",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
    ]
}
